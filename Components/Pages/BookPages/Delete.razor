@page "/books/delete"
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@using BookStoreApp.Models
@inject IDbContextFactory<BookStoreApp.Data.AppDbContext> DbFactory
@inject NavigationManager NavigationManager
@attribute [Authorize(Policy = "AdminOnly")]



<PageTitle>Delete</PageTitle>

<h1>Delete</h1>

<p>Are you sure you want to delete this?</p>
<div>
    <h2>Book</h2>
    <hr />
    @if (book is null)
    {
        <p><em>Loading...</em></p>
    }
    else {
        <dl class="row">
            <dt class="col-sm-2">Title</dt>
            <dd class="col-sm-10">@book.Title</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Author</dt>
            <dd class="col-sm-10">@book.Author</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Genre</dt>
            <dd class="col-sm-10">@book.Genre</dd>
        </dl>
        <dl class="row">
            <dt class="col-sm-2">Price</dt>
            <dd class="col-sm-10">@book.Price</dd>
        </dl>
        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger">@_error</div>
        }
        <EditForm method="post" Model="book" OnValidSubmit="DeleteBook" FormName="delete" Enhance>
            <button type="submit" class="btn-store-danger" disabled="@(book is null)">Delete</button> |
            <a href="/books">Back to List</a>
        </EditForm>
    }
</div>

@code {
    private Book? book;

    [SupplyParameterFromQuery]
    private int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        book = await context.Books.FirstOrDefaultAsync(m => m.Id == Id);

        if (book is null)
        {
            NavigationManager.NotFound();
        }
    }

    private string? _error;

    private async Task DeleteBook()
    {
        using var context = DbFactory.CreateDbContext();
        var entity = await context.Books.FindAsync(book!.Id);
        if (entity is null)
        {
            NavigationManager.NotFound();
            return;
        }

        // Check for related records
        var hasOrders = await context.OrderItems.AnyAsync(oi => oi.BookId == entity.Id);
        if (hasOrders)
        {
            _error = "Cannot delete this book because it has existing order records.";
            return;
        }

        // Remove related records that can be safely deleted
        var reviews = await context.BookReviews.Where(r => r.BookId == entity.Id).ToListAsync();
        context.BookReviews.RemoveRange(reviews);

        var favorites = await context.FavouriteBooks.Where(f => f.BookId == entity.Id).ToListAsync();
        context.FavouriteBooks.RemoveRange(favorites);

        var cartItems = await context.CartItems.Where(c => c.BookId == entity.Id).ToListAsync();
        context.CartItems.RemoveRange(cartItems);

        context.Books.Remove(entity);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/books");
    }
}
